use "../schemas/auth.wfs"

#[duration=1m]
scenario ssh_brute_quick {
  traffic { stream auth_events gen 500/s }
  injection {
    hit<100%> auth_events {
      sip seq {
        use(result="failed") with(20,5s)
        use(service="ssh") with(20,0s)
        use(user="root") with(20,0s)
      }
    }
  }
  expect { hit(ssh_brute_force) >= 80% }
}
