use "../schemas/auth.wfs"
use "../rules/02-initial_access/ssh_brute_force.wfl"

#[duration=1m]
scenario ssh_brute_quick<seed=42> {
  traffic { stream auth_events gen 500/s }
  injection {
    hit<100%> auth_events {
      sip seq {
        use(result="failed", service="ssh", user="root") with(12)
      }
    }
  }
  expect { hit(ssh_brute_force) >= 80% }
}
